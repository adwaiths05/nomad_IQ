# App
APP_NAME=Nomadiq API
APP_ENV=development
APP_DEBUG=true
APP_VERSION=0.1.0
API_PREFIX=

# Database (Neon) + cache
# Use Neon pooled connection string with asyncpg driver.
DATABASE_URL=postgresql+asyncpg://<neon_user>:<neon_password>@<neon_host>/<neon_db>?sslmode=require
REDIS_URL=redis://redis:6379/0

# Auth
JWT_SECRET_KEY=replace-with-a-strong-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_MINUTES=30
REFRESH_TOKEN_DAYS=14

# LLM + embeddings
LLM_BASE_URL=http://model-runner.docker.internal/engines/v1
LLM_MODEL_NAME=ai/smollm2:360M-Q4_K_M
LLM_API_KEY=
EMBEDDINGS_BASE_URL=http://model-runner.docker.internal/engines/v1
EMBEDDINGS_MODEL_NAME=ai/nomic-embed-text-v1.5
EMBEDDINGS_API_KEY=

# MCP runtime (only travel + rag)
MCP_ENABLED=true
MCP_AUTH_TOKEN=
MCP_TRAVEL_URL=http://mcp-travel:9000
MCP_RAG_URL=http://mcp-rag:9000

# MCP tool names used by API integrations
MCP_TOOL_TRAVEL_SEARCH_FLIGHTS=search_flights
MCP_TOOL_TRAVEL_SEARCH_NOMAD_DEALS=search_nomad_deals
MCP_TOOL_TRAVEL_CITY_SPOTS=get_city_spots
MCP_TOOL_TRAVEL_NEARBY_SPOTS=get_nearby_spots
MCP_TOOL_TRAVEL_TRANSIT_DURATION=calculate_transit_duration
MCP_TOOL_RAG_SEARCH_LONG_TERM=search_long_term_memory
MCP_TOOL_RAG_SEARCH_SHORT_TERM=search_short_term_memory
MCP_TOOL_RAG_STORE=store_memory

# Backend direct API adapters (free-first)
AMADEUS_CLIENT_ID=
AMADEUS_CLIENT_SECRET=
AMADEUS_BASE_URL=https://test.api.amadeus.com
SAFETY_SECONDARY_SIGNAL_ENABLED=true

OPENWEATHER_API_KEY=
OPENWEATHER_BASE_URL=https://api.openweathermap.org/data/2.5
OPENWEATHER_GEO_BASE_URL=https://api.openweathermap.org/geo/1.0

TICKETMASTER_API_KEY=
TICKETMASTER_BASE_URL=https://app.ticketmaster.com/discovery/v2

EXCHANGE_API_BASE_URL=https://open.er-api.com/v6
APIFY_API_TOKEN=
NUMBEO_CITY_COST_ACTOR_ID=

CLIMATIQ_API_KEY=
CLIMATIQ_BASE_URL=https://api.climatiq.io

# Travel MCP optional flight fallbacks
PHOTON_BASE_URL=https://photon.komoot.io
OSRM_BASE_URL=https://router.project-osrm.org
AVIATIONSTACK_API_KEY=
AVIATIONSTACK_BASE_URL=https://api.aviationstack.com/v1
OPENSKY_BASE_URL=https://opensky-network.org/api

# Docker/model pulling + frontend
HF_TOKEN=
NEXT_PUBLIC_API_URL=/api
