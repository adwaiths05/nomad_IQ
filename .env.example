# App
APP_NAME=Nomadiq API
APP_ENV=development
APP_DEBUG=true
APP_VERSION=0.1.0
API_PREFIX=

# Database (required)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/nomadiq

# Auth (required/important)
JWT_SECRET_KEY=replace-with-a-strong-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_MINUTES=30
REFRESH_TOKEN_DAYS=14

# LLM service (required)
LLM_BASE_URL=http://localhost:8001/v1
LLM_MODEL_NAME=mistralai/Mistral-7B-Instruct-v0.2
LLM_API_KEY=

# Embeddings service (required)
EMBEDDINGS_BASE_URL=http://localhost:8002/v1
EMBEDDINGS_MODEL_NAME=nomic-ai/nomic-embed-text-v1.5
EMBEDDINGS_API_KEY=

# MCP integrations (required for external data providers)
MCP_ENABLED=true
MCP_AUTH_TOKEN=

# FastMCP server endpoints
MCP_GOOGLE_MAPS_SERVER_URL=http://localhost:9101
MCP_COMPOSIO_SERVER_URL=http://localhost:9102
MCP_CUSTOM_SERVER_URL=http://localhost:9103

# MCP tool names (override only if your server exports different names)
MCP_TOOL_GOOGLE_PLACES_CITY=google_places_city_productive_spots
MCP_TOOL_GOOGLE_PLACES_NEARBY=google_places_nearby_productive_spots
MCP_TOOL_GOOGLE_ROUTES_TRANSIT=google_routes_transit_duration_minutes
MCP_TOOL_TICKETMASTER_EVENTS=ticketmaster_search_events
MCP_TOOL_OPENWEATHER_FORECAST=openweather_five_day_forecast
MCP_TOOL_EXCHANGE_RATES=exchange_rate_get_rates
MCP_TOOL_NUMBEO_BASELINE=numbeo_city_baseline
MCP_TOOL_AMADEUS_SAFETY=amadeus_safety_score
MCP_TOOL_CLIMATIQ_EMISSIONS=climatiq_estimate_route_emissions
MCP_TOOL_RAG_ENRICH_CONTEXT=rag_enrich_plan_context

# Optional comma-separated tool alias fallbacks for provider-native naming.
MCP_TOOL_GOOGLE_PLACES_CITY_ALIASES=GOOGLE_MAPS_TEXT_SEARCH
MCP_TOOL_GOOGLE_PLACES_NEARBY_ALIASES=GOOGLE_MAPS_TEXT_SEARCH
MCP_TOOL_GOOGLE_ROUTES_TRANSIT_ALIASES=GOOGLE_MAPS_DISTANCE_MATRIX_API
MCP_TOOL_TICKETMASTER_EVENTS_ALIASES=TICKETMASTER_GET_EVENTS
MCP_TOOL_OPENWEATHER_FORECAST_ALIASES=OPENWEATHER_API_GET_CURRENT_WEATHER

# Docker/model pulling (used by docker/llm and docker/embeddings compose)
VLLM_MODEL_NAME=mistralai/Mistral-7B-Instruct-v0.2
# Reuse EMBEDDINGS_MODEL_NAME above for embedding server model id.
HF_TOKEN=
