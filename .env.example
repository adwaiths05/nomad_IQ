# App
APP_NAME=Nomadiq API
APP_ENV=development
APP_DEBUG=true
APP_VERSION=0.1.0
API_PREFIX=

# Database (required)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/nomadiq

# Auth (required/important)
JWT_SECRET_KEY=replace-with-a-strong-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_MINUTES=30
REFRESH_TOKEN_DAYS=14

# LLM service (required)
LLM_BASE_URL=http://localhost:8001/v1
LLM_MODEL_NAME=Qwen/Qwen2.5-7B-Instruct-AWQ
LLM_API_KEY=

# Embeddings service (required)
EMBEDDINGS_BASE_URL=http://localhost:8002/v1
EMBEDDINGS_MODEL_NAME=nomic-ai/nomic-embed-text-v1.5
EMBEDDINGS_API_KEY=

# MCP integrations (required for external data providers)
MCP_ENABLED=true
MCP_AUTH_TOKEN=

# FastMCP server endpoints
MCP_GOOGLE_MAPS_SERVER_URL=http://localhost:9101
MCP_TICKETMASTER_SERVER_URL=http://localhost:9102
MCP_OPENWEATHER_SERVER_URL=http://localhost:9103
MCP_COMPOSIO_SERVER_URL=http://localhost:9102
MCP_CUSTOM_SERVER_URL=http://localhost:9103
MCP_APIFY_SERVER_URL=http://localhost:9104

# MCP tool names (override only if your server exports different names)
MCP_TOOL_GOOGLE_PLACES_CITY=maps_search_places
MCP_TOOL_GOOGLE_PLACES_NEARBY=maps_search_places
MCP_TOOL_GOOGLE_ROUTES_TRANSIT=maps_distance_matrix
MCP_TOOL_TICKETMASTER_EVENTS=search_events
MCP_TOOL_OPENWEATHER_FORECAST=get_five_day_forecast
MCP_TOOL_EXCHANGE_RATES=exchange_rate_get_rates
MCP_TOOL_NUMBEO_BASELINE=numbeo_city_baseline
MCP_TOOL_AMADEUS_SAFETY=amadeus_safety_score
MCP_TOOL_CLIMATIQ_EMISSIONS=climatiq_estimate_route_emissions
MCP_TOOL_RAG_ENRICH_CONTEXT=rag_enrich_plan_context
MCP_TOOL_APIFY_CALL_ACTOR=call-actor
MCP_TOOL_APIFY_GET_ACTOR_OUTPUT=get-actor-output
MCP_APIFY_NUMBEO_ACTOR_ID=
MCP_APIFY_NEWS_ACTOR_ID=GetLatestNewsOnTopic

# Optional comma-separated tool alias fallbacks for provider-native naming.
MCP_TOOL_GOOGLE_PLACES_CITY_ALIASES=maps_search_places,GOOGLE_MAPS_TEXT_SEARCH,google_places_city_productive_spots
MCP_TOOL_GOOGLE_PLACES_NEARBY_ALIASES=maps_search_places,GOOGLE_MAPS_TEXT_SEARCH,google_places_nearby_productive_spots
MCP_TOOL_GOOGLE_ROUTES_TRANSIT_ALIASES=maps_distance_matrix,maps_directions,GOOGLE_MAPS_DISTANCE_MATRIX_API,google_routes_transit_duration_minutes
MCP_TOOL_TICKETMASTER_EVENTS_ALIASES=search_events,TICKETMASTER_GET_EVENTS,ticketmaster_search_events
MCP_TOOL_OPENWEATHER_FORECAST_ALIASES=get_five_day_forecast,openweather_five_day_forecast

# External provider credentials used by MCP bridge containers
GOOGLE_MAPS_API_KEY=
TICKETMASTER_API_KEY=
OPENWEATHER_API_KEY=
APIFY_API_TOKEN=

# Docker/model pulling (used by docker/llm and docker/embeddings compose)
VLLM_MODEL_NAME=Qwen/Qwen2.5-7B-Instruct-AWQ
# Reuse EMBEDDINGS_MODEL_NAME above for embedding server model id.
HF_TOKEN=
